# ============================================================
# CampusThrift — Production Environment Variables Template
# ============================================================
# Copy this file to .env on your GCP Cloud Run deployment
# and fill in all values. NEVER commit the real .env to git!

NODE_ENV=production

# Server
PORT=8080

# MongoDB Atlas — get connection string from atlas.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/campusthrift?retryWrites=true&w=majority

# Frontend URL (Vercel deployment or your custom domain)
CLIENT_URL=https://campusthrift.in

# JWT
JWT_SECRET=<replace-with-a-long-random-secret-min-32-chars>
JWT_EXPIRES_IN=7d

# Email Service: 'brevo' (recommended for production) or 'resend' (if domain verified)
EMAIL_SERVICE=brevo
EMAIL_USER=ram26102004@gmail.com
BREVO_API_KEY=<your-brevo-api-key>
BYPASS_DEV_REDIRECT=false

# Resend (only needed if EMAIL_SERVICE=resend and domain is verified)
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM_ADDRESS=otp@campusthrift.in

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# Stripe (payments)
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
